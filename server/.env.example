# Zarinpal merchant ID (UUID format)
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000

# Use Zarinpal sandbox while testing
ZARINPAL_SANDBOX=true

# Public callback URL (must match what you set in Zarinpal panel)
CALLBACK_URL=https://gandomakshop.ir/payment/callback

# Admin token for /api/orders
ADMIN_TOKEN=please-change-me

# Internal port (Nginx proxies /api -> here)
PORT=8787
