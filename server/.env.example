# Zibal merchant ID (use 'zibal' for public sandbox)
ZIBAL_MERCHANT_ID=68df9f49a45c720017c9e144

# Telegram notifications (leave empty to disable)
# Bot: @Gandomakshopbot — token from BotFather, chat_id from /getUpdates
# DO NOT commit real values here. Set them only in server/.env on the VPS.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Rubika notifications (leave empty to disable)
# Bot: @Gandomakshopbot — token from Rubika BotFather
# To get RUBIKA_CHAT_ID: message the bot in Rubika once, then run:
#   cd server && node rubika-getchat.js
RUBIKA_BOT_TOKEN=
RUBIKA_CHAT_ID=

# Card-to-card destination
CARD_NUMBER=6063731055805767
CARD_HOLDER=سمیرا رشیدی

# Public callback URL (must match what you set in the Zibal panel)
CALLBACK_URL=https://gandomakshop.ir/payment/callback

# Admin token for /api/orders
ADMIN_TOKEN=please-change-me

# Internal port (Nginx proxies /api -> here, and /payment/callback -> here)
PORT=3001

# Public site origin (used to build absolute URLs in the Torob API output)
SITE_ORIGIN=https://gandomakshop.ir

# Torob API v3 — paste the RSA/ECDSA public key (PEM) provided by Torob.
# Leave empty to skip JWT verification (useful for local tests).
# Set TOROB_ENFORCE_JWT=1 to reject requests when the key is missing.
TOROB_PUBLIC_KEY=
TOROB_ENFORCE_JWT=0
